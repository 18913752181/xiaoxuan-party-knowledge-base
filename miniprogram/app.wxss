page {
  min-height: 100%;
  background: #f7f4ed;
  color: #2f3732;
  font-family: -apple-system, BlinkMacSystemFont, "PingFang SC", "Microsoft YaHei", sans-serif;
}

.container {
  padding: 32rpx;
}

.hero-title {
  font-size: 44rpx;
  line-height: 1.25;
  font-weight: 700;
  color: #2f3732;
}

.hero-subtitle {
  margin-top: 18rpx;
  font-size: 28rpx;
  line-height: 1.8;
  color: #69726d;
}

.search-box {
  height: 92rpx;
  margin-top: 28rpx;
  padding: 0 28rpx;
  border-radius: 28rpx;
  background: #fffdf8;
  border: 1rpx solid #e4ded2;
  box-shadow: 0 12rpx 36rpx rgba(72, 63, 49, 0.06);
  font-size: 28rpx;
}

.section-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin: 40rpx 0 20rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #2f3732;
}

.section-more {
  font-size: 24rpx;
  color: #6f8f7e;
}

.card {
  margin-bottom: 24rpx;
  padding: 28rpx;
  border-radius: 28rpx;
  background: #fffdf8;
  border: 1rpx solid #e7e0d5;
  box-shadow: 0 14rpx 40rpx rgba(69, 59, 44, 0.06);
}

.card-title {
  margin-top: 18rpx;
  font-size: 34rpx;
  line-height: 1.45;
  font-weight: 700;
  color: #2f3732;
}

.card-desc {
  margin-top: 14rpx;
  font-size: 27rpx;
  line-height: 1.75;
  color: #646b66;
}

.meta-row {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  align-items: center;
}

.badge {
  display: inline-flex;
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  background: #edf4ef;
  color: #557668;
  font-size: 23rpx;
}

.badge-soft {
  background: #f3eee6;
  color: #7a6955;
}

.action-row {
  display: flex;
  gap: 18rpx;
  margin-top: 24rpx;
}

.primary-btn,
.secondary-btn {
  flex: 1;
  height: 78rpx;
  line-height: 78rpx;
  border-radius: 999rpx;
  font-size: 27rpx;
  text-align: center;
}

.primary-btn {
  background: #6f8f7e;
  color: #ffffff;
}

.secondary-btn {
  background: #fffdf8;
  color: #557668;
  border: 1rpx solid #e4ded2;
}

.topic-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 18rpx;
}

.topic-item {
  width: calc(50% - 9rpx);
  box-sizing: border-box;
  padding: 24rpx;
  border-radius: 24rpx;
  background: #fffdf8;
  border: 1rpx solid #e4ded2;
  font-size: 28rpx;
  color: #38413c;
}

.empty {
  padding: 72rpx 24rpx;
  text-align: center;
  color: #7a807b;
  font-size: 28rpx;
}

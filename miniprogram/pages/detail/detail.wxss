.file-panel,
.content-section {
  margin-bottom: 24rpx;
  padding: 32rpx;
  border-radius: 30rpx;
  background: #fffdf8;
  border: 1rpx solid #e4ded2;
  box-shadow: 0 14rpx 40rpx rgba(69, 59, 44, 0.06);
}

.file-icon {
  display: inline-flex;
  padding: 10rpx 20rpx;
  border-radius: 18rpx;
  background: #edf4ef;
  color: #557668;
  font-size: 26rpx;
  font-weight: 700;
}

.detail-title {
  margin-top: 28rpx;
  font-size: 42rpx;
  line-height: 1.35;
  font-weight: 800;
  color: #2f3732;
}

.detail-desc,
.section-text,
.file-meta {
  margin-top: 18rpx;
  font-size: 28rpx;
  line-height: 1.85;
  color: #5f6862;
  white-space: pre-wrap;
}

.file-meta {
  font-size: 25rpx;
  color: #7a807b;
}

.related-item {
  display: flex;
  justify-content: space-between;
  gap: 20rpx;
  padding: 22rpx 0;
  border-bottom: 1rpx solid #ece5da;
  font-size: 28rpx;
  color: #38413c;
}

.related-item text {
  color: #6f8f7e;
  font-size: 24rpx;
}
